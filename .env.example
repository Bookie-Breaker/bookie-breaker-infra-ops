# infra-ops environment variables (used by Docker Compose)

# ── Database ──────────────────────────────────────────
POSTGRES_PASSWORD=localdev

# ── External API Keys ──���─────────────────────────────
ODDS_API_KEY=your-odds-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Lines ingestion ──────────────────────────────────
# ODDS_API_SPORTS=basketball_nba,soccer_fifa_world_cup,soccer_epl,baseball_mlb
#   Comma-separated Odds API sport keys (compose default shown), e.g.
#   basketball_nba,soccer_fifa_world_cup,soccer_epl,baseball_mlb,americanfootball_nfl,icehockey_nhl
# ODDS_API_POLL_INTERVAL=900          # Seconds; free tier is 500 req/month

# ── Statistics ───────────────────────────────────────
# LEAGUES_ENABLED=NBA,FIFA_WC,EPL,MLB # Comma-separated leagues statistics-service serves (compose default shown)
# INJURY_SOURCE=espn                  # espn | none
# CFBD_API_KEY=your-cfbd-api-key     # NCAA_FB season stats; free key at https://collegefootballdata.com (free tier has a monthly call cap; season aggregates only, never scores)
# CBBD_API_KEY=your-cbbd-api-key     # NCAA_BB season stats; free key at https://collegebasketballdata.com (free tier has a monthly call cap; season aggregates only, never scores)

# ── Season-start enablement ──────────────────────────
# NFL, NCAA_FB, NHL, and NCAA_BB ship dormant: their leagues are off-season
# and polling them wastes Odds API quota. At each season start, uncomment
# the matching pair below (cumulative), run `task down && task up`, and
# enable the agent schedule via `bb pipeline schedule set`:
# Sept:  ODDS_API_SPORTS=basketball_nba,soccer_fifa_world_cup,soccer_epl,baseball_mlb,americanfootball_nfl,americanfootball_ncaaf
#        LEAGUES_ENABLED=NBA,FIFA_WC,EPL,MLB,NFL,NCAA_FB
# Oct:   ODDS_API_SPORTS=basketball_nba,soccer_fifa_world_cup,soccer_epl,baseball_mlb,americanfootball_nfl,americanfootball_ncaaf,icehockey_nhl
#        LEAGUES_ENABLED=NBA,FIFA_WC,EPL,MLB,NFL,NCAA_FB,NHL
# Nov:   ODDS_API_SPORTS=basketball_nba,soccer_fifa_world_cup,soccer_epl,baseball_mlb,americanfootball_nfl,americanfootball_ncaaf,icehockey_nhl,basketball_ncaab
#        LEAGUES_ENABLED=NBA,FIFA_WC,EPL,MLB,NFL,NCAA_FB,NHL,NCAA_BB

# ── LLM ──────────────────────────────────────────────
# Compose defaults the agent to the local Ollama (zero-cost dev, ADR-011);
# set LLM_PROVIDER=anthropic + ANTHROPIC_API_KEY above for cloud models.
OLLAMA_MODEL=phi3:mini                # Pulled by ollama-init on startup (~2.2 GB)
# LLM_PROVIDER=ollama                 # ollama | anthropic
# LLM_BASE_URL=http://ollama:11434    # https://api.anthropic.com for anthropic
# LLM_MODEL=phi3:mini                 # e.g. claude-opus-4-8 for anthropic

# ── Observability ────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# ── Dashboard ────────────────────────────────────────
# UI_ORIGIN=http://localhost:3000     # adapter-node origin check; change if serving elsewhere

# ── Optional overrides ───────────────────────────────
# LOG_LEVEL=debug
# SIMULATION_ITERATIONS=1000          # Lower for faster dev runs (prod: 10000-50000)
# REDIS_URL=redis://redis:6379        # Override if running Redis elsewhere
